# Šablona pro .env – zkopíruj na ".env" a vyplň reálné údaje.
#   cp .env.example .env
# Soubor .env je v .gitignore a NEcommituje se. Tahle šablona ano.

# Zapnout odesílání e-mailu (true/false)
AUTA_MAIL_ENABLED=false

# SMTP server
AUTA_SMTP_HOST=smtp.gmail.com
AUTA_SMTP_PORT=587
AUTA_SMTP_TLS=true       # STARTTLS na portu 587
AUTA_SMTP_SSL=false      # přímé SSL na portu 465 (pak TLS dej false)

# Přihlášení – u Gmailu "App password" (16 znaků), ne hlavní heslo!
AUTA_SMTP_USER=you@example.com
AUTA_SMTP_PASS=xxxxxxxxxxxxxxxx

# Odesílatel / příjemci (víc příjemců odděl čárkou)
AUTA_MAIL_FROM=you@example.com
AUTA_MAIL_TO=you@example.com

# Kolik aut ukázat v TOP přehledu
AUTA_MAIL_TOPN=5

# Poslat e-mail jen když je nějaká změna (true/false). Vhodné pro častý běh
# (např. po hodině) – při běhu beze změny se nic neodešle.
AUTA_MAIL_ONLY_ON_CHANGE=true
